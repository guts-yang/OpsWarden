# ============================================================
# OpsWarden — 环境变量配置模板
# AI-Powered Operations Digital Employee Platform
# ============================================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填写所有 CHANGE_ME 标记的字段
#   3. 切勿将 .env 提交到 Git（已加入 .gitignore）
# ============================================================
# 运行环境：development | production
APP_ENV=development
# 应用名称（用于日志标识）
APP_NAME=OpsWarden
# 后端服务端口
APP_PORT=8000
# API 根路径前缀
API_PREFIX=/api/v1
# 调试模式（生产环境务必设为 false）
DEBUG=true
# 允许跨域的前端地址（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# ------------------------------------------------------------
# MySQL 数据库配置
# ------------------------------------------------------------
# 数据库连接串（SQLAlchemy 格式，含 utf8mb4 字符集）
DATABASE_URL=mysql+pymysql://ops:CHANGE_ME@mysql:3306/opswarden?charset=utf8mb4
# MySQL 普通用户（与 docker-compose.yml 中 MYSQL_USER 保持一致）
MYSQL_USER=ops
# MySQL 普通用户密码
MYSQL_PASSWORD=CHANGE_ME
# MySQL root 密码（仅 Docker 初始化使用）
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
# 数据库名称
MYSQL_DATABASE=opswarden
# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
# ------------------------------------------------------------
# DeepSeek 大模型 API 配置
# ------------------------------------------------------------
# DeepSeek API 密钥（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-CHANGE_ME
# DeepSeek API 地址（兼容 OpenAI 格式，无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 使用的模型名称
DEEPSEEK_MODEL=deepseek-chat
# 对话温度（0~1，运维场景建议 0.1 保证确定性）
DEEPSEEK_TEMPERATURE=0.1
# 单次最大输出 token 数
DEEPSEEK_MAX_TOKENS=800
# API 请求超时时间（秒）
DEEPSEEK_TIMEOUT=30
# ------------------------------------------------------------
# RAG 知识库配置
# ------------------------------------------------------------
# ChromaDB 本地持久化路径（Docker Volume 挂载点）
CHROMA_PATH=./chroma_db
# ChromaDB 服务地址（Docker 内部通信地址）
CHROMA_HOST=chromadb
CHROMA_PORT=8001
# 向量知识库 Collection 名称
CHROMA_COLLECTION=ops_faq
# Embedding 模型名称（首次运行自动从 HuggingFace 下载）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Embedding 推理设备（无 GPU 填 cpu）
EMBEDDING_DEVICE=cpu
# RAG 检索相似度阈值（ChromaDB cosine距离，越小越相似）
# 低于此阈值视为知识库无答案，自动触发工单
# 推荐范围：0.35 ~ 0.55，可通过 scripts/tune_threshold.py 调优
RAG_SCORE_THRESHOLD=0.4
# RAG 默认召回条数
RAG_TOP_K=3
# 问答结果缓存时长（秒），0 表示不缓存
RAG_CACHE_TTL=3600
# 问答缓存最大条数
RAG_CACHE_MAX_SIZE=200
# ------------------------------------------------------------
# JWT 鉴权配置
# ------------------------------------------------------------
# JWT 签名密钥（生产环境请使用随机长字符串）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_RANDOM_STRING
# JWT 签名算法
JWT_ALGORITHM=HS256
# Access Token 有效期（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
# Refresh Token 有效期（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# ------------------------------------------------------------
# 飞书机器人配置
# ------------------------------------------------------------
# 飞书应用 ID（从飞书开放平台 → 我的应用 获取）
FEISHU_APP_ID=cli_CHANGE_ME
# 飞书应用密钥
FEISHU_APP_SECRET=CHANGE_ME
# 飞书 Webhook 验证 Token（用于验证消息签名）
FEISHU_VERIFICATION_TOKEN=CHANGE_ME
# 飞书消息加解密 Key（如开启加密则填写，否则留空）
FEISHU_ENCRYPT_KEY=
# 值班运维人员的飞书 Open ID（工单创建时推送通知）
# 多个用逗号分隔：ou_xxx,ou_yyy
FEISHU_ONCALL_OPEN_IDS=ou_CHANGE_ME
# 飞书 API 基础地址（无需修改）
FEISHU_BASE_URL=https://open.feishu.cn
# ------------------------------------------------------------
# 前端配置（Vue3，以 VITE_ 前缀暴露给浏览器）
# ------------------------------------------------------------
# 后端 API 地址（前端请求目标）
VITE_API_BASE_URL=http://localhost:8000/api/v1
# 应用标题
VITE_APP_TITLE=OpsWarden
# 版本号
VITE_APP_VERSION=1.0.0
# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------
# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# 日志输出格式：json | text
LOG_FORMAT=text
# 日志文件路径（留空则只输出到 stdout）
LOG_FILE=./logs/opswarden.log
# 单个日志文件最大大小（MB）
LOG_MAX_SIZE_MB=50
# 日志文件保留天数
LOG_RETENTION_DAYS=30
# ------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------
# 密码最小长度
PASSWORD_MIN_LENGTH=8
# 账号最大连续登录失败次数（超过则冻结）
MAX_LOGIN_ATTEMPTS=5
# 账号冻结后自动解冻等待时间（分钟，0 表示不自动解冻）
ACCOUNT_LOCKOUT_MINUTES=30
# 密码有效期（天，0 表示永不过期）
PASSWORD_EXPIRE_DAYS=90
# Session 超时时间（分钟）
SESSION_TIMEOUT_MINUTES=480
# ------------------------------------------------------------
# 运维脚本配置
# ------------------------------------------------------------
# 初始化脚本调用的 API 地址
API_BASE_URL=http://localhost:8000
# 压测脚本并发用户数
STRESS_TEST_CONCURRENCY=10
# 压测持续时间（秒）
STRESS_TEST_DURATION=30