# ============================================================
# OpsWarden — 环境变量模板（与 backend/app/config.py 一致）
# ============================================================
# 使用：复制为仓库根目录 .env
#   copy .env.example .env   （Windows）
# Docker Compose 会为 backend 注入 DATABASE_URL（覆盖下方本地默认值）；
# 数据库密码请与 POSTGRES_PASSWORD、DATABASE_URL 中密码一致。
# ============================================================

# ------------------------------------------------------------
# Docker / PostgreSQL（Compose 与本地通用）
# ------------------------------------------------------------
# 与 docker-compose.yml 中 postgres 服务一致（默认 342802）
POSTGRES_PASSWORD=CHANGE_ME_OR_USE_DEFAULT_IN_COMPOSE

# 若本机访问 registry-1.docker.io 走 IPv6 失败，可为 build / pull 指定镜像站（任选其一或留空用官方）
# 示例（DaoCloud 公共库，路径与 Docker Hub library/命名空间一致）：
# DOCKERHUB_PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.11-slim-bookworm
# DOCKERHUB_NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
# DOCKERHUB_NGINX_IMAGE=docker.m.daocloud.io/library/nginx:alpine
# POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg16

# 本地直连 PostgreSQL（非容器或端口映射时使用）
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/opswarden

# ------------------------------------------------------------
# 应用与鉴权（FastAPI / Settings）
# ------------------------------------------------------------
SECRET_KEY=CHANGE_ME_USE_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------
# DeepSeek 大模型
# ------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_TOKENS=800
DEEPSEEK_TIMEOUT=30

# ------------------------------------------------------------
# RAG / 向量检索（pgvector 存于 PostgreSQL，无独立向量库容器）
# ------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
RAG_SCORE_THRESHOLD=0.4
RAG_TOP_K=3
RAG_ANCHOR_TOP_K=8
ANCHOR_QUANT_EPSILON=0.02

# ------------------------------------------------------------
# 前端本地开发（Vite；生产 Docker 前端走同源 /api，一般无需改）
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_TITLE=OpsWarden
VITE_APP_VERSION=1.0.0

# ------------------------------------------------------------
# 可选：脚本与其它工具（extra=ignore，后端未使用则忽略）
# ------------------------------------------------------------
# API_BASE_URL=http://localhost:8000
# 使用国内镜像站加速下载
POSTGRES_IMAGE=docker.1panel.live/pgvector/pgvector:pg16
DOCKERHUB_PYTHON_IMAGE=docker.1panel.live/library/python:3.11-slim-bookworm
DOCKERHUB_NODE_IMAGE=docker.1panel.live/library/node:20-alpine
DOCKERHUB_NGINX_IMAGE=docker.1panel.live/library/nginx:alpine